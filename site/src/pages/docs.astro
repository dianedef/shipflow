---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";

const coreDocs = [
  ["AGENT.md", "Where a fresh agent should look first depending on the task."],
  ["CONTEXT.md", "How to orient quickly in the repo, identify hotspots, and route edits."],
  ["CONTEXT-FUNCTION-TREE.md", "How to navigate large procedural shell files without re-reading everything."],
  ["README.md", "Public overview, positioning, onboarding, and high-level framework story."],
  ["shipflow-spec-driven-workflow.md", "The execution doctrine behind sf-spec, sf-ready, sf-start, and sf-verify."]
];

const decisionDocs = [
  ["BUSINESS.md", "For whom the product exists, what value it creates, and what model it may support."],
  ["PRODUCT.md", "What the product does, which workflows matter, and which non-goals should stay out."],
  ["BRANDING.md", "How the product should sound, what it can claim, and how trust is earned."],
  ["GTM.md", "How the product is presented publicly, which objections matter, and what proof supports it."],
  ["ARCHITECTURE.md", "How the system is organized, where boundaries sit, and which invariants hold."],
  ["GUIDELINES.md", "How contributors should work inside the repo and which technical rules stay stable."]
];
---

<BaseLayout
  title="ShipFlow Docs | Navigation and contracts"
  description="Documentation entrypoint for ShipFlow: context layer, workflow doctrine, and decision contracts."
>
  <main class="page-shell">
    <NavBar />

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Docs Overview</p>
        <h1 class="page-title">The docs are built for fast agent navigation, not for encyclopedic sprawl.</h1>
        <p>
          ShipFlow documentation is structured so a fresh agent can find the
          right context, understand the decision surface, and execute against
          explicit contracts instead of guessing from chat history.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Core Navigation</p>
        <h2>Start here when you need orientation.</h2>
      </div>

      <div class="doc-grid">
        {
          coreDocs.map(([name, body]) => (
            <article class="doc-card">
              <h3>{name}</h3>
              <p>{body}</p>
              <a class="doc-action" href={`https://github.com/dianedef/ShipFlow/blob/main/${name}`}>
                Open on GitHub
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="section-heading">
        <p class="eyebrow">Decision Contracts</p>
        <h2>Each document has one explicit role.</h2>
        <p>
          Business, product, brand, GTM, architecture, and guidelines are kept
          separate on purpose. That separation avoids duplicate logic, stale
          context, and conflicting contracts.
        </p>
      </div>

      <div class="doc-grid">
        {
          decisionDocs.map(([name, body]) => (
            <article class="doc-card">
              <h3>{name}</h3>
              <p>{body}</p>
              <a class="doc-action" href={`https://github.com/dianedef/ShipFlow/blob/main/${name}`}>
                Open on GitHub
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section">
      <div class="cta-panel">
        <p class="eyebrow">Execution Logic</p>
        <h2>Use the docs as product contracts, not as passive notes.</h2>
        <p>
          The context layer tells the agent where to start. The decision
          contracts tell it what matters. The workflow doctrine tells it how to
          move from ambiguity reduction to verified delivery.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="https://github.com/dianedef/ShipFlow/blob/main/AGENT.md">Start with AGENT.md</a>
          <a class="button button-secondary" href="https://github.com/dianedef/ShipFlow/blob/main/shipflow-spec-driven-workflow.md">Read the workflow doctrine</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
